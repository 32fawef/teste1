local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

-- 1. SISTEMA DE SEGURANÇA PARA A INTERFACE (Evita tela gigante)
local guiName = "AuditoriaGUI_Segura"
local targetParent

-- Tenta colocar no CoreGui (escondido do jogo). Se o executor bloquear, coloca no PlayerGui.
local sucesso = pcall(function() targetParent = game:GetService("CoreGui") end)
if not sucesso or not targetParent then
    targetParent = LocalPlayer:WaitForChild("PlayerGui")
end

-- Limpa versões anteriores para não bugar
for _, v in pairs(targetParent:GetChildren()) do
    if v.Name == guiName then v:Destroy() end
end

-- 2. CRIANDO A INTERFACE COM TAMANHOS EXATOS (Em Pixels)
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = guiName
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = targetParent

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 200, 0, 130) -- Tamanho exato: 200 de largura, 130 de altura
MainFrame.Position = UDim2.new(0, 50, 0, 50)
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.BorderSizePixel = 2
MainFrame.BorderColor3 = Color3.fromRGB(0, 0, 0)
MainFrame.Active = true
MainFrame.Draggable = true -- Você pode arrastar pela tela
MainFrame.Parent = ScreenGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 14
Title.Font = Enum.Font.Code
Title.Text = "PAINEL DE AUDITORIA"
Title.Parent = MainFrame

local ESPBtn = Instance.new("TextButton")
ESPBtn.Size = UDim2.new(0, 180, 0, 35)
ESPBtn.Position = UDim2.new(0, 10, 0, 40) -- Posição exata do botão ESP
ESPBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
ESPBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ESPBtn.Font = Enum.Font.Code
ESPBtn.TextSize = 14
ESPBtn.Text = "ESP: DESLIGADO"
ESPBtn.Parent = MainFrame

local AimbotBtn = Instance.new("TextButton")
AimbotBtn.Size = UDim2.new(0, 180, 0, 35)
AimbotBtn.Position = UDim2.new(0, 10, 0, 85) -- Posição exata do botão Aimbot
AimbotBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
AimbotBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
AimbotBtn.Font = Enum.Font.Code
AimbotBtn.TextSize = 14
AimbotBtn.Text = "AIMBOT: DESLIGADO"
AimbotBtn.Parent = MainFrame

-- 3. VARIÁVEIS DE CONTROLE
local espAtivo = false
local aimbotAtivo = false

-- 4. FUNÇÕES DE LIGAR/DESLIGAR
ESPBtn.MouseButton1Click:Connect(function()
    espAtivo = not espAtivo
    if espAtivo then
        ESPBtn.Text = "ESP: LIGADO"
        ESPBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0) -- Fica verde
    else
        ESPBtn.Text = "ESP: DESLIGADO"
        ESPBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0) -- Fica vermelho
        -- Apaga o ESP imediatamente ao desligar
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("AuditoriaESP") then
                p.Character.AuditoriaESP:Destroy()
            end
        end
    end
end)

AimbotBtn.MouseButton1Click:Connect(function()
    aimbotAtivo = not aimbotAtivo
    if aimbotAtivo then
        AimbotBtn.Text = "AIMBOT: LIGADO"
        AimbotBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        AimbotBtn.Text = "AIMBOT: DESLIGADO"
        AimbotBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    end
end)

-- 5. LOOP DE EXECUÇÃO (O motor do script)
RunService.RenderStepped:Connect(function()
    -- Lógica do ESP
    if espAtivo then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if p.Team ~= LocalPlayer.Team then -- Team Check
                    local hl = p.Character:FindFirstChild("AuditoriaESP")
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "AuditoriaESP"
                        hl.FillColor = Color3.fromRGB(255, 0, 0)
                        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                        hl.Parent = p.Character
                    end
                end
            end
        end
    end

    -- Lógica do Aimbot
    if aimbotAtivo then
        local alvo = nil
        local menorDistancia = 200 -- Alcance da trava de mira na tela
        
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                if p.Team ~= LocalPlayer.Team then -- Team Check
                    local cabeca = p.Character.Head
                    local posNaTela, taNaTela = Camera:WorldToViewportPoint(cabeca.Position)
                    
                    if taNaTela then
                        local centroTela = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                        local dist = (Vector2.new(posNaTela.X, posNaTela.Y) - centroTela).Magnitude
                        
                        if dist < menorDistancia then
                            menorDistancia = dist
                            alvo = p
                        end
                    end
                end
            end
        end
        
        if alvo and alvo.Character and alvo.Character:FindFirstChild("Head") then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, alvo.Character.Head.Position)
        end
    end
end)
