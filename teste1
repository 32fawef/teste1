-- =============================================
-- LÓGICA DO ESP
-- =============================================
local _ESP = false
local EspFolder = Instance.new("Folder")
EspFolder.Name = "ESP_Boxes"
EspFolder.Parent = workspace

local function limparESP()
    for _, v in pairs(EspFolder:GetChildren()) do
        v:Destroy()
    end
end

local function criarBox(character, name)
    if EspFolder:FindFirstChild(name) then return end
    local box = Instance.new("SelectionBox")
    box.Name = name
    box.Adornee = character
    box.Color3 = Color3.new(1, 0, 0)       -- Vermelho
    box.SurfaceColor3 = Color3.new(1, 0, 0)
    box.SurfaceTransparency = 0.7
    box.LineThickness = 0.05
    box.AlwaysOnTop = true                  -- Vê através das paredes
    box.Parent = EspFolder
end

-- Botão toggle ESP
EspBtn.MouseButton1Click:Connect(function()
    _ESP = not _ESP
    if _ESP then
        EspBtn.Text = "ESP: ATIVADO ✔"
        EspBtn.BackgroundColor3 = Color3.fromRGB(0, 130, 0)
    else
        EspBtn.Text = "ESP: DESATIVADO"
        EspBtn.BackgroundColor3 = Color3.fromRGB(120, 0, 0)
        limparESP()
    end
end)

-- Minimizar / Maximizar
local minimizado = false
MinBtn.MouseButton1Click:Connect(function()
    minimizado = not minimizado
    if minimizado then
        Content.Visible = false
        MainFrame.Size = UDim2.new(0, 180, 0, 28)
        MinBtn.Text = "+"
    else
        Content.Visible = true
        MainFrame.Size = UDim2.new(0, 180, 0, 90)
        MinBtn.Text = "—"
    end
end)

-- =============================================
-- LOOP PRINCIPAL - Detecta TODOS os Humanoids
-- =============================================
RunService.RenderStepped:Connect(function()
    if not _ESP then return end

    -- Varre TODOS os modelos no workspace que tenham Humanoid
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local character = obj.Parent
            if character and character ~= LocalPlayer.Character then
                local root = character:FindFirstChild("HumanoidRootPart")
                    or character:FindFirstChildWhichIsA("BasePart")

                if root then
                    local boxName = "ESP_" .. character.Name .. "_" .. tostring(character:GetDebugId())
                    local existing = EspFolder:FindFirstChild(boxName)

                    if not existing then
                        criarBox(character, boxName)
                    else
                        -- Atualiza adornee caso tenha mudado
                        existing.Adornee = character
                    end
                end
            end
        end
    end

    -- Remove boxes de personagens que morreram ou sumiram
    for _, box in pairs(EspFolder:GetChildren()) do
        if not box.Adornee or not box.Adornee.Parent then
            box:Destroy()
        end
    end
end)

-- Limpeza ao sair
LocalPlayer.AncestryChanged:Connect(function()
    pcall(function() EspFolder:Destroy() end)
end)
