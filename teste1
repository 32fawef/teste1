local _ESP = false
local _AIM = false
local minimizado = false

-- ============================================================
-- ESP - USA HIGHLIGHT (FUNCIONA ATRAVÉS DA PAREDE SEMPRE)
-- ============================================================
local EspFolder = Instance.new("Folder")
EspFolder.Name = "ESP_Highlights"
EspFolder.Parent = workspace

local function limparESP()
    for _, v in pairs(EspFolder:GetChildren()) do v:Destroy() end
end

local function aplicarHighlight(character, id)
    if EspFolder:FindFirstChild(id) then return end

    -- HIGHLIGHT: método mais confiável para ver através de paredes
    local hl = Instance.new("Highlight")
    hl.Name = id
    hl.Adornee = character
    hl.FillColor = Color3.new(1, 0, 0)       -- Vermelho por dentro
    hl.OutlineColor = Color3.new(1, 1, 1)    -- Branco por fora
    hl.FillTransparency = 0.5                -- Semi-transparente
    hl.OutlineTransparency = 0               -- Contorno sólido
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- ATRAVESSA PAREDE
    hl.Parent = EspFolder
end

-- ============================================================
-- AIMBOT PODEROSO
-- ============================================================
local function getMelhorAlvo()
    local melhor = nil
    local menorDist = AIM_FOV
    local centro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local bone = p.Character:FindFirstChild(AIM_BONE)
            local hum = p.Character:FindFirstChild("Humanoid")

            if bone and hum and hum.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(bone.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - centro).Magnitude
                    if dist < menorDist then
                        menorDist = dist
                        melhor = p
                    end
                end
            end
        end
    end
    return melhor
end

