-- ============================================================
-- LOOP PRINCIPAL — RenderStepped (antes de cada frame)
-- ============================================================
RunService.RenderStepped:Connect(function()
    if not _AIM then return end

    local alvo = getMelhorAlvo()
    if not alvo or not alvo.Character then return end

    -- Randomização de parte do corpo (evita 100% headshot)
    local partName
    if CFG.RANDOMIZE and math.random() < CFG.RAND_CHANCE then
        partName = "HumanoidRootPart"
    else
        partName = "Head"
    end

    local part = alvo.Character:FindFirstChild(partName)
    if not part then
        part = alvo.Character:FindFirstChild("HumanoidRootPart")
    end
    if not part then return end

    -- Previsão de movimento: mira onde o inimigo ESTARÁ
    local vel = getVelocidade(alvo)
    local posAlvo = part.Position + (vel * CFG.PREDICTION)

    -- Calcula distância na tela para smoothing progressivo
    local sp, onScreen = Camera:WorldToViewportPoint(posAlvo)
    if not onScreen then return end
    local centro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local distPixels = (Vector2.new(sp.X, sp.Y) - centro).Magnitude

    -- Smoothing progressivo: mais lento quando perto do alvo
    local smooth = calcularSmooth(distPixels)

    -- Move a câmera com Lerp suave
    local camPos = Camera.CFrame.Position
    local targetCF = CFrame.new(camPos, posAlvo)
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, smooth)
end)

