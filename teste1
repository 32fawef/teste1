local _AIM = false

-- ============================================================
-- RAYCASTING — Verifica se o alvo está visível (sem parede)
-- ============================================================
local function estaVisivel(targetPart)
    if not CFG.RAYCAST then return true end

    local localChar = LocalPlayer.Character
    if not localChar then return false end
    local localHRP = localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return false end

    local origem   = localHRP.Position
    local direcao  = (targetPart.Position - origem)
    local distancia = direcao.Magnitude

    -- Parâmetros do Raycast: ignora o próprio personagem
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {localChar}
    params.FilterType = Enum.RaycastFilterType.Exclude

    local resultado = workspace:Raycast(origem, direcao.Unit * distancia, params)

    if resultado then
        -- Se o raycast bateu em algo que é parte do personagem alvo = visível
        local inst = resultado.Instance
        local alvoChar = targetPart.Parent
        if inst:IsDescendantOf(alvoChar) then
            return true
        end
        return false  -- Bateu em parede ou outro objeto
    end

    return true  -- Nada bloqueando = visível
end

-- ============================================================
-- PREVISÃO DE MOVIMENTO
-- Calcula velocidade do inimigo para mirar onde ele ESTARÁ
-- ============================================================
local lastPositions = {}

local function getVelocidade(player)
    local char = player.Character
    if not char then return Vector3.new(0,0,0) end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return Vector3.new(0,0,0) end

    local uid = player.UserId
    local now = hrp.Position

    if lastPositions[uid] then
        local vel = (now - lastPositions[uid]) * 60  -- Velocidade por segundo
        lastPositions[uid] = now
        return vel
    else
        lastPositions[uid] = now
        return Vector3.new(0,0,0)
    end
end

-- ============================================================
-- SELEÇÃO DE ALVO: Mais próximo do centro dentro do FOV
-- Prioriza alvos visíveis (sem parede)
-- ============================================================
local function getMelhorAlvo()
    local melhor, menorDist = nil, math.huge
    local centro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if CFG.TEAM_CHECK and p.Team == LocalPlayer.Team then continue end

        local char = p.Character
        if not char then continue end

        -- Usa Head para cálculo de FOV (mais preciso para mira)
        local head = char:FindFirstChild("Head")
        local hum  = char:FindFirstChild("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end

        local sp, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then continue end

        local d = (Vector2.new(sp.X, sp.Y) - centro).Magnitude
        if d > CFG.FOV then continue end

        -- Verifica visibilidade via Raycast
        if not estaVisivel(head) then continue end

        if d < menorDist then
            menorDist = d
            melhor = p
        end
    end

    return melhor
end

-- ============================================================
-- SMOOTHING PROGRESSIVO
-- Quanto mais perto do alvo, mais lento fica (evita tremido)
-- ============================================================
local function calcularSmooth(distanciaPixels)
    -- Quando longe do alvo: usa smooth base
    -- Quando perto do alvo: reduz smooth para não tremer
    local fator = math.clamp(distanciaPixels / CFG.FOV, 0.1, 1.0)
    return CFG.SMOOTH * (0.5 + fator * 0.5)
end

