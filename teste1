local CFG = {
    -- AIMBOT
    AIM_KEY       = Enum.KeyCode.Q,   -- Tecla para ativar
    AIM_FOV       = 600,              -- Raio de detecção (pixels)
    AIM_SMOOTH    = 0.18,             -- Suavidade: 0.05=lento, 1.0=snap
    AIM_BONE      = "Head",           -- Osso alvo: "Head" ou "HumanoidRootPart"
    AIM_PREDICT   = true,             -- Ativar predição de movimento
    AIM_WALLCHECK = true,             -- Não mirar através de paredes
    AIM_RANDOM    = 0.4,              -- Ruído humano (0=robô, 2=muito ruído)

    -- SPEED
    SPEED_LEVEL   = 5,                -- Nível 1-10
    SPEED_BASE    = 16,               -- WalkSpeed padrão do Roblox
    SPEED_CFRAME  = false,            -- Usar CFrame bypass (mais difícil de detectar)
    SPEED_CFRAME_DIST = 0.8,          -- Distância por teleporte (metros)
}

