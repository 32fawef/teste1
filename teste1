-- ============================================================
-- RAYCAST
-- ============================================================
local function estaVisivel(origem, targetPart)
    if not CFG.RAYCAST then return true end
    local localChar = LocalPlayer.Character
    local alvoChar  = targetPart.Parent
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {localChar, alvoChar}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local direcao = targetPart.Position - origem
    local resultado = workspace:Raycast(origem, direcao, params)
    return resultado == nil
end

-- ============================================================
-- SELEÇÃO DE ALVO
-- ============================================================
local function getMelhorAlvo()
    local melhor, menorDist = nil, math.huge
    local centro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local camPos = Camera.CFrame.Position

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if CFG.TEAM_CHECK and p.Team == LocalPlayer.Team then continue end
        local char = p.Character
        if not char then continue end
        local part = char:FindFirstChild(CFG.TARGET_PART) or char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChild("Humanoid")
        if not part or not hum or hum.Health <= 0 then continue end
        local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local d = (Vector2.new(sp.X, sp.Y) - centro).Magnitude
        if d > CFG.FOV then continue end
        if not estaVisivel(camPos, part) then continue end
        if d < menorDist then
            menorDist = d
            melhor = p
        end
    end

    return melhor, menorDist
end

