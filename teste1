local function setBtn(btn, state, onText, offText)
    btn.Text = state and onText or offText
    btn.BackgroundColor3 = state and Color3.fromRGB(0, 130, 0) or Color3.fromRGB(80, 0, 0)
    local s = btn:FindFirstChildOfClass("UIStroke")
    if s then s.Color = state and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(120, 0, 0) end
end

