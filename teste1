    end
end)

-- ============================================================
-- LOOP PRINCIPAL
-- ============================================================
RunService.RenderStepped:Connect(function()

    -- === ESP ===
    if _ESP then
        -- Jogadores
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    local id = "HL_Player_" .. p.UserId
                    local ex = EspFolder:FindFirstChild(id)
                    if not ex then
                        aplicarHighlight(p.Character, id)
                    else
                        ex.Adornee = p.Character
                    end
                end
            end
        end

        -- NPCs / Mobs (qualquer Humanoid no workspace)
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Humanoid") and obj.Health > 0 then
                local char = obj.Parent
                if char and char ~= LocalPlayer.Character then
                    local id = "HL_NPC_" .. tostring(char:GetDebugId())
                    if not EspFolder:FindFirstChild(id) then
                        aplicarHighlight(char, id)
                    end
                end
            end
        end

        -- Remove highlights de alvos mortos/sumidos
        for _, hl in pairs(EspFolder:GetChildren()) do
            if not hl.Adornee or not hl.Adornee.Parent then
                hl:Destroy()
            end
        end
    end

    -- === AIMBOT ===
    if _AIM and UserInputService:IsKeyDown(AIM_KEY) then
        local alvo = getMelhorAlvo()
        if alvo and alvo.Character and alvo.Character:FindFirstChild(AIM_BONE) then
            local targetPos = alvo.Character[AIM_BONE].Position
            Camera.CameraType = Enum.CameraType.Scriptable

            -- Suavização: interpola entre CFrame atual e o alvo
            local currentCF = Camera.CFrame
            local targetCF = CFrame.new(currentCF.Position, targetPos)
            Camera.CFrame = currentCF:Lerp(targetCF, AIM_SMOOTH)
        end
    elseif _AIM and not UserInputService:IsKeyDown(AIM_KEY) then
        if Camera.CameraType == Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Custom
        end
    end
end)

