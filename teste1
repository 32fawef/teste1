-- ============================================================
-- 🎯 MOUSE LOCK - A TECNICA CERTA!
-- Em vez de mexer na câmera, movemos o MOUSE suavemente
-- Isso NÃO conflata com NADA e é 100% natural
-- ============================================================
local function moverMouseSuave(dx, dy)
    -- Move o mouse relativamente (não absoluto)
    local sucesso, erro = pcall(function()
        local move = Vector2.new(dx, dy)
        local currentPos = UIS:GetMouseLocation()
        local novaPos = currentPos + move
        -- Usa método de simulação de input
        local mouseDelta = Vector2.new(dx, dy)
        -- Emulate move
        mousemoverel(dx, dy)  -- Função nativa do Roblox
    end)
end

RunService.RenderStepped:Connect(function()
    -- ESP
    if _ESP then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local char = p.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    if not char:FindFirstChild("_ZurionESP") then
                        local box = Instance.new("SelectionBox")
                        box.Name = "_ZurionESP"
                        box.Adornee = char
                        box.Color3 = Color3.fromRGB(0, 255, 127)
                        box.LineAlpha = 0.8
                        box.AlwaysOnTop = true
                        box.Parent = char
                    end
                end
            end
        end
    end

    -- Aimbot
    if not _AIM then return end

    local alvo, distPixels = getMelhorAlvo()
    if not alvo or not alvo.Character then return end

    local head = alvo.Character:FindFirstChild("Head")
    local hrp  = alvo.Character:FindFirstChild("HumanoidRootPart")
    local part = head or hrp
    if not part then return end

    -- Posição do alvo na tela
    local posTela, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen then return end

    local centroTela = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local posAlvo2D = Vector2.new(posTela.X, posTela.Y)

    -- Distância do centro (em pixels)
    local diff = posAlvo2D - centroTela
    local distCentro = diff.Magnitude

    -- Zona morta (evita tremedeira quando já está apontando)
    if distCentro < CFG.DEADZONE then return end

    -- Calcula quanto mover o mouse
    local moverX = diff.X * CFG.MOUSE_SPEED * CFG.SMOOTH
    local moverY = diff.Y * CFG.MOUSE_SPEED * CFG.SMOOTH

    -- Snap quando muito perto do alvo
    if distCentro < CFG.SNAP_DIST then
        moverX = diff.X * 0.5  -- Mais rápido quando perto
        moverY = diff.Y * 0.5
    end

    -- Move o mouse suavemente
    mousemoverel(moverX, moverY)
end)

