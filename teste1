    FovCircle.Visible = Settings.Aimbot.Enabled
    FovCircle.Size = UDim2.new(0, Settings.Aimbot.Fov * 2, 0, Settings.Aimbot.Fov * 2)
    
    UpdateESP()

    -- Lógica de Mira
    if Settings.Aimbot.Enabled then
        CurrentTarget = GetClosestTarget()
        
        if CurrentTarget and CurrentTarget.Character then
            local head = CurrentTarget.Character:FindFirstChild(Settings.Aimbot.TargetPart)
            local hrp = CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
            
            if head and hrp then
                -- Cálculo de Predição
                local velocity = hrp.Velocity
                local targetPos = head.Position + (velocity * Settings.Aimbot.Prediction)
                
                -- Movimento da Câmera
                local targetCFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, Settings.Aimbot.Smoothness)
            end
        end
    end
end)

