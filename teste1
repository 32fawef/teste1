-- ============================================================
-- LOOP PRINCIPAL
-- ============================================================
RunService.RenderStepped:Connect(function()

    -- === ESP: SelectionBox ===
    if _ESP then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    aplicarESP(p.Character)
                end
            end
        end
    end

    -- === AIMBOT v9: FOV + câmera livre + mais forte ===
    if _AIM then
        local alvo = getMelhorAlvoNoFOV()
        if alvo and alvo.Character then
            local hrp = alvo.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Lerp 0.25 = mais forte que v8 (era 0.1), câmera ainda livre
                local targetCF = CFrame.new(Camera.CFrame.Position, hrp.Position)
                Camera.CFrame = Camera.CFrame:Lerp(targetCF, 0.25)
            end
        end
    end
end)

-- Limpeza ao sair
LocalPlayer.AncestryChanged:Connect(function()
    pcall(limparESP)
end)
