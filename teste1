-- Função Criar Botão Pro
local function AddToggle(name, default, callback)
    local btn = Instance.new("TextButton", Container)
    btn.Text = name .. ": " .. (default and "ON" or "OFF")
    btn.BackgroundColor3 = default and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn)
    
    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name .. ": " .. (state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(30, 30, 30)
        callback(state)
    end)
end

-- [[ SISTEMA DE FOV ]] --
local FOV_Circle = Instance.new("ImageLabel", ScreenGui)
FOV_Circle.AnchorPoint = Vector2.new(0.5, 0.5)
FOV_Circle.Position = UDim2.new(0.5, 0, 0.5, 0)
FOV_Circle.Size = UDim2.new(0, Settings.FOV*2, 0, Settings.FOV*2)
FOV_Circle.Image = "rbxassetid://2851939495"
FOV_Circle.ImageColor3 = Color3.new(1, 0, 0)
FOV_Circle.BackgroundTransparency = 1
FOV_Circle.Visible = false

-- [[ LOGICA RIVALS ]] --
local function getTarget()
    local target, dist = nil, Settings.FOV
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            -- Team Check (Opcional)
            if Settings.TeamCheck and p.Team == LocalPlayer.Team then continue end
            
            local pos, onScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < dist then
                    dist = mag
                    target = p
                end
            end
        end
    end
    return target
end

-- [[ ADICIONAR FUNÇÕES ]] --
AddToggle("Aimbot", false, function(v) Settings.Aimbot = v; FOV_Circle.Visible = v end)
AddToggle("Silent Aim", false, function(v) Settings.SilentAim = v end)
AddToggle("ESP Box", false, function(v) Settings.ESP = v end)
AddToggle("No Recoil", false, function(v) Settings.NoRecoil = v end)

-- [[ LOOP DE EXECUÇÃO ]] --
RunService.RenderStepped:Connect(function()
    local target = getTarget()
    
    -- Aimbot Visível
    if Settings.Aimbot and target then
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Character.Head.Position), Settings.Smoothness)
    end
    
    -- ESP Box e Highlight
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hl = p.Character:FindFirstChild("ZurionHL")
            if Settings.ESP then
                if not hl then
                    hl = Instance.new("Highlight", p.Character)
                    hl.Name = "ZurionHL"
                    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    hl.FillColor = Color3.new(1, 0, 0)
                end
            elseif hl then hl:Destroy() end
        end
    end
end)

-- No Recoil (Simulação para Rivals)
LocalPlayer.CharacterAdded:Connect(function(char)
    if Settings.NoRecoil then
        -- No Rivals, o recoil é controlado por scripts locais de arma. 
        -- Este comando tenta resetar o tremor da camera.
        RunService.Heartbeat:Connect(function()
            if Settings.NoRecoil and Settings.Aimbot then
                 Camera.CFrame = Camera.CFrame * CFrame.Angles(0,0,0)
            end
        end)
    end
end)
