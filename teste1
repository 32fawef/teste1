-- Aimbot: encontra alvo mais próximo do centro
local function getMelhorAlvo()
    local melhor, menorDist = nil, AIM_FOV
    local centro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local hum  = p.Character:FindFirstChild("Humanoid")
            if head and hum and hum.Health > 0 then
                local sp, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local d = (Vector2.new(sp.X, sp.Y) - centro).Magnitude
                    if d < menorDist then menorDist = d; melhor = p end
                end
            end
        end
    end
    return melhor
end

-- Loop principal
RunService.RenderStepped:Connect(function()
    -- ESP
    if _ESP then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    local id = "HL_" .. p.UserId
                    local ex = EspFolder:FindFirstChild(id)
                    if not ex then aplicarHighlight(p.Character, id)
                    else ex.Adornee = p.Character end
                end
            end
        end
        for _, hl in pairs(EspFolder:GetChildren()) do
            if not hl.Adornee or not hl.Adornee.Parent then hl:Destroy() end
        end
    end

    -- AIMBOT
    if _AIM and UserInputService:IsKeyDown(AIM_KEY) then
        local alvo = getMelhorAlvo()
        if alvo and alvo.Character and alvo.Character:FindFirstChild("Head") then
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, alvo.Character.Head.Position)
        else
            Camera.CameraType = Enum.CameraType.Custom
        end
    elseif _AIM then
        if Camera.CameraType == Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Custom
        end
    end
end)

