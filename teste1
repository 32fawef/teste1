local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()
local RunService = game:GetService("RunService")

-- 1. INTERFACE DE CONTROLE
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Painel_Zurion_Real"
ScreenGui.Parent = game:GetService("CoreGui") or LocalPlayer:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 160, 0, 100)
Frame.Position = UDim2.new(0, 50, 0, 50)
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Frame.Active = true
Frame.Draggable = true
Frame.Parent = ScreenGui

local EspBtn = Instance.new("TextButton", Frame)
EspBtn.Size = UDim2.new(1, 0, 0.5, 0)
EspBtn.Text = "ESP: OFF"
EspBtn.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
EspBtn.TextColor3 = Color3.new(1,1,1)

local AimBtn = Instance.new("TextButton", Frame)
AimBtn.Size = UDim2.new(1, 0, 0.5, 0)
AimBtn.Position = UDim2.new(0, 0, 0.5, 0)
AimBtn.Text = "AIMBOT: OFF"
AimBtn.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
AimBtn.TextColor3 = Color3.new(1,1,1)

-- VARIÁVEIS DE ESTADO
local _ESP = false
local _AIM = false

EspBtn.MouseButton1Click:Connect(function()
    _ESP = not _ESP
    EspBtn.Text = _ESP and "ESP: ON" or "ESP: OFF"
    EspBtn.BackgroundColor3 = _ESP and Color3.new(0, 0.5, 0) or Color3.new(0.5, 0, 0)
end)

AimBtn.MouseButton1Click:Connect(function()
    _AIM = not _AIM
    AimBtn.Text = _AIM and "AIMBOT: ON" or "AIMBOT: OFF"
    AimBtn.BackgroundColor3 = _AIM and Color3.new(0, 0.5, 0) or Color3.new(0.5, 0, 0)
end)

-- LÓGICA DE EXECUÇÃO
RunService.RenderStepped:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            -- ESP: USANDO SELECTIONBOX (ATRAVESSA TUDO)
            local box = p.Character:FindFirstChild("Auditoria_Box")
            if _ESP and p.Character:FindFirstChild("HumanoidRootPart") then
                if not box then
                    box = Instance.new("SelectionBox")
                    box.Name = "Auditoria_Box"
                    box.Adornee = p.Character
                    box.Color3 = Color3.new(1, 0, 0)
                    box.LineAlpha = 0.5 -- Transparência da linha
                    box.AlwaysOnTop = true -- GARANTE VER ATRAVÉS DA PAREDE
                    box.Parent = p.Character
                end
            else
                if box then box:Destroy() end
            end
        end
    end

    -- AIMBOT: TRAVA DE MIRA REAL
    if _AIM then
        local target = nil
        local dist = 1000
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                if p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local pos, screen = Camera:WorldToViewportPoint(p.Character.Head.Position)
                    if screen then
                        local mDist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if mDist < dist then
                            dist = mDist
                            target = p
                        end
                    end
                end
            end
        end
        if target then
            -- MODO AGRESSIVO: Força a CFrame da Câmera a olhar para o Alvo
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.Head.Position)
        end
    end
end)
