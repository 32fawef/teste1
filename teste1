-- CONFIGURAÇÕES DO SISTEMA
local Settings = {
    AimbotEnabled = true,
    TeamCheck = true,
    FriendCheck = true, -- Não foca em amigos
    Smoothing = 0.5,    -- Quanto maior, mais "suave" e menos perceptível (0.1 a 1)
    AimPart = "Head",   -- Parte do corpo alvo
    FieldOfView = 150   -- Área de alcance do Aimbot
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = game:GetService("Workspace").CurrentCamera
local RunService = game:GetService("RunService")

-- FUNÇÃO PARA FILTRAR ALVOS VÁLIDOS
local function isTargetValid(player)
    if not player.Character or not player.Character:FindFirstChild(Settings.AimPart) then return false end
    if player == LocalPlayer then return false end
    
    -- Filtro de Time
    if Settings.TeamCheck and player.Team == LocalPlayer.Team then return false end
    
    -- Filtro de Amigos (Friend Check)
    if Settings.FriendCheck and LocalPlayer:IsFriendsWith(player.UserId) then return false end
    
    return true
end

-- FUNÇÃO PARA PEGAR O JOGADOR MAIS PRÓXIMO DA MIRA (Cursor)
local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = Settings.FieldOfView

    for _, player in pairs(Players:GetPlayers()) do
        if isTargetValid(player) then
            local pos, onScreen = Camera:WorldToViewportPoint(player.Character[Settings.AimPart].Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                if distance < shortestDistance then
                    closestPlayer = player
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

-- LOOP DE EXECUÇÃO (Render)
RunService.RenderStepped:Connect(function()
    if Settings.AimbotEnabled then
        local target = getClosestPlayer()
        if target and target.Character:FindFirstChild(Settings.AimPart) then
            -- Lógica de Aimbot Suave (Smoothing)
            local targetPos = Camera:WorldToViewportPoint(target.Character[Settings.AimPart].Position)
            local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            
            -- Move a câmera suavemente em direção ao alvo
            local aimAt = Vector2.new(targetPos.X, targetPos.Y)
            -- Nota: Em ambientes de teste reais, o movimento da câmera é o principal ponto de detecção
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character[Settings.AimPart].Position)
        end
    end
end)

print("Sistema de Auditoria: Aimbot e FriendCheck ativos.")
