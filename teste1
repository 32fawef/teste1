local function setBtn(btn, state, onText, offText)
    btn.Text = state and onText or offText
    btn.BackgroundColor3 = state and Color3.fromRGB(0, 140, 0) or Color3.fromRGB(100, 0, 0)
end

EspBtn.MouseButton1Click:Connect(function()
    _ESP = not _ESP
    setBtn(EspBtn, _ESP, "ESP: ON ✔", "ESP: OFF")
    if not _ESP then limparESP() end
end)

AimBtn.MouseButton1Click:Connect(function()
    _AIM = not _AIM
    setBtn(AimBtn, _AIM, "AIMBOT: ON ✔", "AIMBOT: OFF")
    FovFrame.Visible = _AIM

    -- CHAVE: Scriptable = aimbot controla câmera sem interferência
    -- Custom = câmera normal do jogador
    if _AIM then
        Camera.CameraType = Enum.CameraType.Scriptable
    else
        Camera.CameraType = Enum.CameraType.Custom
    end
end)

SpeedBtn.MouseButton1Click:Connect(function()
    _SPEED = not _SPEED
    setBtn(SpeedBtn, _SPEED, "SPEED: ON ✔", "SPEED: OFF")
    aplicarSpeed()
end)

FovMinus.MouseButton1Click:Connect(function()
    FOV_RADIUS = math.max(60, FOV_RADIUS - 20)
    FovFrame.Size = UDim2.new(0, FOV_RADIUS * 2, 0, FOV_RADIUS * 2)
    FovLbl.Text = "FOV: " .. FOV_RADIUS .. "px"
end)

FovPlus.MouseButton1Click:Connect(function()
    FOV_RADIUS = math.min(500, FOV_RADIUS + 20)
    FovFrame.Size = UDim2.new(0, FOV_RADIUS * 2, 0, FOV_RADIUS * 2)
    FovLbl.Text = "FOV: " .. FOV_RADIUS .. "px"
end)

MinusBtn.MouseButton1Click:Connect(function()
    speedLevel = math.max(1, speedLevel - 1)
    atualizarSpeedUI()
end)

PlusBtn.MouseButton1Click:Connect(function()
    speedLevel = math.min(10, speedLevel + 1)
    atualizarSpeedUI()
end)

-- ============================================================
-- LOOP PRINCIPAL
-- ============================================================
RunService.RenderStepped:Connect(function()

    -- === ESP: SelectionBox AlwaysOnTop ===
    if _ESP then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    aplicarESP(p.Character)
                end
            end
        end
        -- Limpa ESP de jogadores mortos ou que saíram
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid")
                local box = p.Character:FindFirstChild("ZurionESP")
                if box and hum and hum.Health <= 0 then
                    box:Destroy()
                end
            end
        end
    end

    -- === AIMBOT v11: Scriptable + Lerp 0.35 ===
    if _AIM then
        local alvo = getMelhorAlvo()
        if alvo and alvo.Character then
            local hrp = alvo.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local camPos = Camera.CFrame.Position
                local targetCF = CFrame.new(camPos, hrp.Position)
                -- Lerp 0.35 = forte, mas ainda suave
                Camera.CFrame = Camera.CFrame:Lerp(targetCF, 0.35)
            end
        end
    end
end)

-- Limpeza ao sair
LocalPlayer.AncestryChanged:Connect(function()
    pcall(limparESP)
    pcall(function() Camera.CameraType = Enum.CameraType.Custom end)
end)
