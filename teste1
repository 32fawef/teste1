-- ============================================================
-- GERENCIADOR DE ALVOS (SISTEMA DE PREDIÇÃO)
-- ============================================================
local CurrentTarget = nil

local function GetRaycastTarget(part)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    
    local direction = (part.Position - Camera.CFrame.Position).Unit * 1000
    local result = workspace:Raycast(Camera.CFrame.Position, direction, params)
    
    if result and result.Instance:IsDescendantOf(part.Parent) then
        return true
    end
    return false
end

local function GetClosestTarget()
    local bestTarget = nil
    local maxDist = Settings.Aimbot.Fov
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild(Settings.Aimbot.TargetPart)
            local hum = player.Character:FindFirstChild("Humanoid")
            
            if head and hum and hum.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                
                if onScreen then
                    local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    
                    if mouseDist < maxDist then
                        if Settings.Aimbot.WallCheck then
                            if GetRaycastTarget(head) then
                                maxDist = mouseDist
                                bestTarget = player
                            end
                        else
                            maxDist = mouseDist
                            bestTarget = player
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

