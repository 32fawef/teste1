-- ============================================================
-- ESTADO
-- ============================================================
local _ESP      = false
local _AIM      = false
local _SPEED    = false
local speedLevel = 5

-- ============================================================
-- ESP: SelectionBox com AlwaysOnTop (versão original que funcionava)
-- Colocado diretamente no personagem, não em pasta separada
-- ============================================================
local function limparESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local box = p.Character:FindFirstChild("ZurionESP")
            if box then box:Destroy() end
        end
    end
end

local function aplicarESP(character)
    -- Remove highlight antigo se existir (de versões anteriores)
    local oldHL = character:FindFirstChildOfClass("Highlight")
    if oldHL then oldHL:Destroy() end

    if character:FindFirstChild("ZurionESP") then return end

    local box = Instance.new("SelectionBox")
    box.Name = "ZurionESP"
    box.Adornee = character
    box.Color3 = Color3.new(1, 0, 0)
    box.LineThickness = 0.05
    box.SurfaceTransparency = 0.7
    box.SurfaceColor3 = Color3.new(1, 0, 0)
    box.AlwaysOnTop = true  -- VÊ ATRAVÉS DAS PAREDES
    box.Parent = character  -- Dentro do personagem (não em pasta)
end

-- ============================================================
-- AIMBOT v11: CameraType.Scriptable quando ativo
-- Isso impede que o Roblox sobrescreva o CFrame ao mexer a tela
-- ============================================================
local function getMelhorAlvo()
    local melhor, menorDist = nil, math.huge
    local centro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local sp, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local d = (Vector2.new(sp.X, sp.Y) - centro).Magnitude
                    if d <= FOV_RADIUS and d < menorDist then
                        menorDist = d
                        melhor = p
                    end
                end
            end
        end
    end
    return melhor
end

-- ============================================================
-- SPEED
-- ============================================================
local function getWalkSpeed()
    return SPEED_BASE + speedLevel * 14
end

local function aplicarSpeed()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = _SPEED and getWalkSpeed() or SPEED_BASE
    end
end

local function atualizarSpeedUI()
    SpeedLbl.Text = string.format("Velocidade: nível %d (WalkSpeed %d)", speedLevel, getWalkSpeed())
    if _SPEED then aplicarSpeed() end
end

LocalPlayer.CharacterAdded:Connect(function(char)
    if _SPEED then
        task.wait(0.5)
        local hum = char:WaitForChild("Humanoid")
        hum.WalkSpeed = getWalkSpeed()
    end
end)

