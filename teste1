-- ============================================================
-- LÓGICA DE ESP ROBUSTA
-- ============================================================
local function UpdateESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local id = "Zurion_ESP_" .. player.Name
            
            if Settings.ESP.Enabled then
                -- Highlight
                local hl = char:FindFirstChild("Z_HL")
                if not hl and Settings.ESP.Highlights then
                    hl = Instance.new("Highlight", char)
                    hl.Name = "Z_HL"
                    hl.OutlineTransparency = 0
                    hl.FillTransparency = 0.5
                end
                if hl then
                    hl.FillColor = Settings.ESP.Color
                    hl.Enabled = true
                end

                -- Box
                local box = char:FindFirstChild("Z_Box")
                if not box and Settings.ESP.Boxes then
                    box = Instance.new("SelectionBox", char)
                    box.Name = "Z_Box"
                    box.AlwaysOnTop = true
                    box.LineAlpha = 0.7
                    box.Adornee = char
                end
                if box then
                    box.Color3 = Settings.ESP.Color
                    box.Visible = true
                end
            else
                if char:FindFirstChild("Z_HL") then char["Z_HL"]:Destroy() end
                if char:FindFirstChild("Z_Box") then char["Z_Box"]:Destroy() end
            end
        end
    end
end

