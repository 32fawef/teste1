-- ============================================================
-- ESP COM HIGHLIGHT (ATRAVESSA PAREDE)
-- ============================================================
local EspFolder = Instance.new("Folder")
EspFolder.Name = "ESP_Folder"
EspFolder.Parent = workspace

local function limparESP()
    for _, v in pairs(EspFolder:GetChildren()) do v:Destroy() end
end

local function aplicarHighlight(character, id)
    if EspFolder:FindFirstChild(id) then return end
    local hl = Instance.new("Highlight")
    hl.Name = id; hl.Adornee = character
    hl.FillColor = Color3.new(1,0,0); hl.OutlineColor = Color3.new(1,1,1)
    hl.FillTransparency = 0.5; hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = EspFolder
end

-- ============================================================
-- WALLCHECK: Raio invisível para checar linha de visão
-- ============================================================
local function temLinhaDeVisao(targetPos)
    local origin = Camera.CFrame.Position
    local direction = (targetPos - origin)
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, workspace.Terrain}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(origin, direction, rayParams)
    -- Se o raio não bateu em nada, ou bateu muito perto do alvo = linha de visão livre
    if not result then return true end
    local hitDist = (result.Position - origin).Magnitude
    local totalDist = direction.Magnitude
    return hitDist >= totalDist * 0.85
end

-- ============================================================
-- AIMBOT: ENCONTRA ALVO MAIS PRÓXIMO DO CENTRO
-- ============================================================
local function getMelhorAlvo()
    local melhor, menorDist = nil, CFG.AIM_FOV
    local centro = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local bone = p.Character:FindFirstChild(CFG.AIM_BONE)
            local hum  = p.Character:FindFirstChild("Humanoid")
            if bone and hum and hum.Health > 0 then
                local sp, onScreen = Camera:WorldToViewportPoint(bone.Position)
                if onScreen then
                    local d = (Vector2.new(sp.X, sp.Y) - centro).Magnitude
                    if d < menorDist then
                        -- Wallcheck opcional
                        if not CFG.AIM_WALLCHECK or temLinhaDeVisao(bone.Position) then
                            menorDist = d; melhor = p
                        end
                    end
                end
            end
        end
    end
    return melhor
end

-- ============================================================
-- PREDIÇÃO DE MOVIMENTO (Motion Prediction)
-- Calcula onde o alvo estará baseado na velocidade atual
-- ============================================================
local lastPositions = {}

local function getPosicaoPredita(player)
    local char = player.Character
    if not char then return nil end
    local bone = char:FindFirstChild(CFG.AIM_BONE)
    if not bone then return nil end

    local currentPos = bone.Position
    local uid = player.UserId

    if not CFG.AIM_PREDICT then return currentPos end

    -- Calcula velocidade baseada na posição anterior
    local predicted = currentPos
    if lastPositions[uid] then
        local velocity = currentPos - lastPositions[uid]
        -- Projeta a posição para o próximo frame (compensação de latência)
        local pingFactor = 2.5  -- Ajuste baseado no ping médio
        predicted = currentPos + velocity * pingFactor
    end
    lastPositions[uid] = currentPos
    return predicted
end

-- ============================================================
-- SPEED HACK
-- ============================================================
local function getWalkSpeed()
    return CFG.SPEED_BASE + CFG.SPEED_LEVEL * 14
end

local function aplicarSpeed()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = _SPEED and getWalkSpeed() or CFG.SPEED_BASE end
end

-- CFrame Bypass: teleportes pequenos e rápidos
local lastCFrameTime = 0
local function cframeBurst(dt)
    if not _SPEED or not CFG.SPEED_CFRAME then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.MoveDirection.Magnitude < 0.1 then return end

    lastCFrameTime = lastCFrameTime + dt
    if lastCFrameTime < 0.016 then return end  -- ~60fps
    lastCFrameTime = 0

    local dir = hum.MoveDirection
    local dist = CFG.SPEED_CFRAME_DIST * (CFG.SPEED_LEVEL / 5)
    hrp.CFrame = hrp.CFrame + dir * dist
end

-- ============================================================
-- CONTROLE DO AIMBOT (InputBegan/Ended para não bugar câmera)
-- ============================================================
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == CFG.AIM_KEY and _AIM then
        aiming = true
        Camera.CameraType = Enum.CameraType.Scriptable
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == CFG.AIM_KEY then
        aiming = false
        Camera.CameraType = Enum.CameraType.Custom
    end
end)

