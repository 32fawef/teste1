local function atualizarSpeedUI()
    local ws = getWalkSpeed()
    SpeedLbl.Text = string.format("Velocidade: %d  (nível %d/10)", ws, CFG.SPEED_LEVEL)
    if _SPEED then aplicarSpeed() end
end

MinusBtn.MouseButton1Click:Connect(function()
    CFG.SPEED_LEVEL = math.max(1, CFG.SPEED_LEVEL - 1)
    atualizarSpeedUI()
end)

PlusBtn.MouseButton1Click:Connect(function()
    CFG.SPEED_LEVEL = math.min(10, CFG.SPEED_LEVEL + 1)
    atualizarSpeedUI()
end)

local function atualizarSmoothUI()
    SmoothLbl.Text = string.format("Smooth: %d%%  (Lerp)", math.floor(CFG.AIM_SMOOTH * 100))
end

SMinBtn.MouseButton1Click:Connect(function()
    CFG.AIM_SMOOTH = math.max(0.05, math.floor((CFG.AIM_SMOOTH - 0.05) * 100 + 0.5) / 100)
    atualizarSmoothUI()
end)

SPlusBtn.MouseButton1Click:Connect(function()
    CFG.AIM_SMOOTH = math.min(1.0, math.floor((CFG.AIM_SMOOTH + 0.05) * 100 + 0.5) / 100)
    atualizarSmoothUI()
end)

-- Restaura speed ao respawnar
LocalPlayer.CharacterAdded:Connect(function(char)
    if _SPEED then
        task.wait(0.5)
        local hum = char:WaitForChild("Humanoid")
        hum.WalkSpeed = getWalkSpeed()
    end
end)

-- ============================================================
-- LOOP PRINCIPAL
-- ============================================================
RunService.RenderStepped:Connect(function(dt)

    -- === ESP ===
    if _ESP then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    local id = "HL_" .. p.UserId
                    local ex = EspFolder:FindFirstChild(id)
                    if not ex then aplicarHighlight(p.Character, id)
                    else ex.Adornee = p.Character end
                end
            end
        end
        for _, hl in pairs(EspFolder:GetChildren()) do
            if not hl.Adornee or not hl.Adornee.Parent then hl:Destroy() end
        end
    end

    -- === AIMBOT COM LERP + PREDICTION + RANDOMIZAÇÃO ===
    if aiming and _AIM then
        local alvo = getMelhorAlvo()
        if alvo then
            local targetPos = getPosicaoPredita(alvo)
            if targetPos then
                -- Adiciona ruído humano (randomização anti-detecção)
                local noise = CFG.AIM_RANDOM
                targetPos = targetPos + Vector3.new(
                    (math.random() - 0.5) * noise,
                    (math.random() - 0.5) * noise,
                    (math.random() - 0.5) * noise
                )

                -- LERP: Interpolação linear suave (simula movimento humano)
                -- Em vez de pular direto, move CFG.AIM_SMOOTH% em direção ao alvo por frame
                local currentLook = Camera.CFrame.LookVector
                local targetLook  = (targetPos - Camera.CFrame.Position).Unit
                local smoothLook  = currentLook:Lerp(targetLook, CFG.AIM_SMOOTH)

                Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + smoothLook)
            end
        end
    end

    -- === SPEED HACK (CFrame Bypass) ===
    cframeBurst(dt)
end)

